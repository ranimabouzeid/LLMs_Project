# ---- Google Cloud / Vertex AI ----
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id_here
GOOGLE_CLOUD_LOCATION=your_google_cloud_location_here
# Note: Use 'gcloud auth application-default login' to authenticate

# ---- Model Settings ----
GEMINI_MODEL=gemini-2.5-flash

# ---- RAG settings ----
RETRIEVAL_TOP_K=5
JUDGE_THRESHOLD=5.0
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ---- Local Persistence ----
# Path to the SQLite student database
STUDENT_DB_PATH=data/student.db

# Path to the ChromaDB vector storage
CHROMA_DB_PATH=data/vector_db

# ---- Domain ----
DOMAIN=machine_learning
PREREQ_GRAPH_PATH=data/prerequisite_graph.json
QA_EXAMPLES_PATH=finetuning/qa_examples.json
