# ---- Google Cloud / Vertex AI (MANDATORY) ----
# The ID of your Google Cloud Project
GOOGLE_CLOUD_PROJECT=your_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1

# AUTHENTICATION NOTE:
# Run 'gcloud auth application-default login' on your machine.
# This allows the app to securely use your Vertex AI credentials.

# ---- Optional / Secondary Config ----
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---- RAG settings ----
RETRIEVAL_TOP_K=5
JUDGE_THRESHOLD=5.0
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ---- Local Persistence (Paths) ----
STUDENT_DB_PATH=data/student.db
CHROMA_DB_PATH=data/vector_db

# ---- Domain Settings ----
DOMAIN=machine_learning
DOMAIN_PROMPT_PATH=pipeline/domain_prompt.txt
PREREQ_GRAPH_PATH=data/prerequisite_graph.json
QA_EXAMPLES_PATH=finetuning/qa_examples.json
